# Conexão PostgreSQL VPS (vars separadas — suporta qualquer caractere na senha)
PG_HOST=seu-host-aqui
PG_PORT=5432
PG_USER=seu-usuario-aqui
PG_PASSWORD=sua-senha-aqui
PG_DATABASE=seu-banco-aqui

# Chaves CNPJA (adicione quantas precisar: KEY_3, KEY_4...)
CNPJA_API_KEY_1=sua-chave-aqui
CNPJA_API_KEY_2=sua-chave-aqui

# Porta do servidor (EasyPanel define automaticamente via PORT)
PORT=3001

# Segurança: chave exigida em todo request ao /api/* (header x-api-key)
# Gere uma string aleatória forte. Mesmo valor deve estar no frontend (VITE_BACKEND_API_KEY)
BACKEND_API_KEY=sua-chave-secreta-aqui

# CORS: origens permitidas (separadas por vírgula)
# Dev: http://localhost:8080  |  PRD: https://seudominio.com
ALLOWED_ORIGINS=http://localhost:8080
